import React, { useState, useEffect } from 'react';
import { View, FlatList, StyleSheet } from 'react-native';
import { searchProperties } from '../../api';
import PropertyCard from '../../components/layout/PropertyCard';
import LoadingSpinner from '../../components/shared/LoadingSpinner';
import Colors from '../../theme/colors';

export default function ListingScreen({ route, navigation }) {
  const [results, setResults] = useState([]);
  const [loading, setLoading] = useState(true);
  const query = route.params?.query || {};

  useEffect(() => {
    searchProperties(query).then(res => setResults(res.data.data?.data || [])).finally(() => setLoading(false));
  }, []);

  if (loading) return <LoadingSpinner />;

  return (
    <View style={styles.container}>
      <FlatList 
        data={results} 
        keyExtractor={(item) => item.id.toString()} 
        renderItem={({ item }) => <PropertyCard item={item} onPress={() => navigation.navigate('PropertyDetails', { slug: item.slug })} />} 
        contentContainerStyle={{ padding: 15 }}
      />
    </View>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: Colors.white }
});

