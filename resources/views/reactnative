import React, { useState } from 'react';
import { View, Text, StyleSheet, Alert, ScrollView } from 'react-native';
import { createBooking } from '../../api';
import Button from '../../components/shared/Button';
import Colors from '../../theme/colors';
import { Feather } from '@expo/vector-icons';

export default function CheckoutScreen({ route, navigation }) {
  const listing = route.params.listing;
  const [loading, setLoading] = useState(false);

  const handleBooking = async () => {
    setLoading(true);
    try {
      await createBooking({ 
        listing_id: listing.id, 
        check_in: '2024-12-01', 
        check_out: '2024-12-03', 
        guests: 2, 
        total_price: listing.base_price * 2 
      });
      Alert.alert('Success', 'Booking confirmed!');
      navigation.navigate('Trips');
    } catch (e) {
      Alert.alert('Error', 'Failed to book');
    } finally { setLoading(false); }
  };

  return (
    <ScrollView style={styles.container}>
      <Text style={styles.title}>Review your booking</Text>
      
      <View style={styles.card}>
        <Text style={styles.cardTitle}>{listing.title}</Text>
        <View style={styles.detailRow}>
          <Feather name="calendar" size={20} color={Colors.brand} />
          <Text style={styles.detailText}>Dec 1 - Dec 3 (2 Nights)</Text>
        </View>
        <View style={styles.detailRow}>
          <Feather name="users" size={20} color={Colors.brand} />
          <Text style={styles.detailText}>2 Guests</Text>
        </View>
      </View>

      <View style={styles.card}>
        <Text style={styles.cardTitle}>Price Details</Text>
        <View style={styles.priceRow}>
          <Text style={styles.priceText}>Rs {listing.base_price} x 2 nights</Text>
          <Text style={styles.priceText}>Rs {listing.base_price * 2}</Text>
        </View>
        <View style={[styles.priceRow, { marginTop: 10 }]}>
          <Text style={styles.totalText}>Total</Text>
          <Text style={styles.totalText}>Rs {listing.base_price * 2}</Text>
        </View>
      </View>

      <View style={styles.paymentCard}>
        <Feather name="credit-card" size={24} color={Colors.brand} />
        <Text style={styles.paymentText}>Pay at Property (Cash)</Text>
      </View>

      <Button title="Confirm Booking" onPress={handleBooking} loading={loading} />
    </ScrollView>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: Colors.slate50, padding: 20 },
  title: { fontSize: 24, fontWeight: 'bold', color: Colors.dark, marginBottom: 20 },
  card: { backgroundColor: Colors.white, padding: 20, borderRadius: 16, marginBottom: 15 },
  cardTitle: { fontSize: 18, fontWeight: 'bold', color: Colors.dark, marginBottom: 15 },
  detailRow: { flexDirection: 'row', alignItems: 'center', gap: 10, marginBottom: 10 },
  detailText: { fontSize: 16, color: Colors.slate600 },
  priceRow: { flexDirection: 'row', justifyContent: 'space-between' },
  priceText: { fontSize: 16, color: Colors.slate600 },
  totalText: { fontSize: 18, fontWeight: 'bold', color: Colors.dark },
  paymentCard: { flexDirection: 'row', alignItems: 'center', gap: 15, backgroundColor: Colors.white, padding: 20, borderRadius: 16, marginBottom: 30, borderWidth: 1, borderColor: Colors.brand },
  paymentText: { fontSize: 16, fontWeight: 'bold', color: Colors.dark }
